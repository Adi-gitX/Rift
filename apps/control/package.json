{
  "name": "@raft/control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@raft/shared-types": "workspace:*",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.6.4",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@raft/eslint-config": "workspace:*",
    "@raft/tsconfig": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "~2.1.9",
    "wrangler": "^3.96.0"
  }
}
